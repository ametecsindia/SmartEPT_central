<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SmartEPT — Employee Productivity Tracking & Intelligence | By Ametecs</title>
<meta name="description" content="SmartEPT by Ametecs — employee productivity tracking with your data on your servers. Attendance, screenshots, app usage, gate-to-PC biometric unlock. From ₹29/device/month.">
<meta property="og:title" content="SmartEPT — Your Data. Your Servers. Total Productivity Visibility.">
<meta property="og:description" content="Employee productivity tracking & intelligence from ₹29/device/month. Client-hosted or SmartEPT Cloud. Industry-first Gate-to-PC unlock.">
<style>
:root{
  --accent:#0E7C8F; --accent2:#22B8CF; --accent-weak:#E3F4F7; --deep:#0B6373;
  --ink:#15171C; --ink2:#565A66; --ink3:#878C99; --canvas:#FFFFFF; --card:#FFFFFF;
  --card2:#FAFBFC; --border:#E7E9EF; --border2:#DCDFE7; --hairline:#F0F1F4;
  --ok:#08875D; --ok-w:#E6F5EE; --warn:#B7791F; --warn-w:#FBF3E2; --danger:#D02748;
  --cov1:#04252C; --cov2:#083A44; --cov3:#0B4A56;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;overflow-x:hidden}
body{font-family:'Inter','Segoe UI',-apple-system,sans-serif;color:var(--ink);background:#FBFAF6;line-height:1.6;font-size:16px;overflow-x:hidden;width:100%}
img{max-width:100%;height:auto}
a{text-decoration:none;color:inherit}
.wrap{max-width:1180px;margin:0 auto;padding:0 24px}
.kicker{text-transform:uppercase;letter-spacing:2.5px;font-size:12px;font-weight:800;color:var(--accent)}
h2.sec{font-size:34px;font-weight:800;line-height:1.2;margin:10px 0 14px;letter-spacing:-.5px}
p.sec-sub{color:var(--ink2);font-size:17px;max-width:720px}
.btn{display:inline-block;padding:14px 28px;border-radius:10px;font-weight:700;font-size:15.5px;cursor:pointer;border:none;transition:all .18s}
.btn-primary{background:linear-gradient(135deg,var(--accent),#1899AE);color:#fff;box-shadow:0 4px 14px rgba(14,124,143,.35)}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 22px rgba(14,124,143,.45)}
.btn-ghost{background:transparent;color:#fff;border:1.5px solid rgba(255,255,255,.4)}
.btn-ghost:hover{border-color:#fff;background:rgba(255,255,255,.08)}
.btn-light{background:#fff;color:var(--deep);border:1.5px solid var(--border2)}
.btn-light:hover{border-color:var(--accent);color:var(--accent)}
.badge{display:inline-block;font-size:11.5px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;padding:5px 12px;border-radius:999px}


.usp .ic svg{width:26px;height:26px;color:var(--accent)}
.feat h4 .fi svg{width:18px;height:18px;color:var(--accent)}
.flow-step .n svg{width:20px;height:20px;color:#fff}

/* ===== NAV ===== */
nav{position:sticky;top:0;z-index:200;width:100%;background:rgba(251,250,246,.92);backdrop-filter:blur(10px);box-shadow:0 2px 16px rgba(15,23,42,.07)}
.nav-in{display:flex;align-items:center;gap:26px;height:72px;max-width:1180px;margin:0 auto;padding:0 24px}
.nav-logo img{height:52px;display:block}
.nav-links{display:flex;gap:24px;margin-left:8px;flex:1}
.nav-links a{font-size:14.5px;font-weight:600;color:var(--ink2)}
.nav-links a:hover{color:var(--accent)}
.nav-cta{display:flex;gap:10px;align-items:center}
.nav-cta .login{font-size:14px;font-weight:700;color:var(--deep);padding:9px 16px;border:1.5px solid var(--border2);border-radius:9px}
.nav-cta .login:hover{border-color:var(--accent);color:var(--accent)}
.nav-cta .trial{font-size:14px;padding:10px 18px}
.hamb{display:none;font-size:26px;background:none;border:none;color:var(--ink);cursor:pointer}

/* ===== HERO ===== */
.hero{position:relative;color:#fff;overflow:hidden;background:var(--cov1)}
.hero::before{display:none}
.hero-bg{position:absolute;inset:0;background-size:cover;background-position:center right}
.hero-veil{position:absolute;inset:0;background:linear-gradient(97deg,#04252C 0%,rgba(4,37,44,.97) 30%,rgba(6,42,49,.86) 52%,rgba(8,58,68,.38) 78%,rgba(8,58,68,.22) 100%)}
.hero-veil2{position:absolute;inset:0;background:linear-gradient(0deg,rgba(4,37,44,.92) 0%,rgba(4,37,44,.25) 26%,transparent 45%)}
.hero-in{position:relative;z-index:2;max-width:1180px;margin:0 auto;padding:104px 24px 150px;min-height:660px;display:flex;flex-direction:column;justify-content:center}
.hero .kicker{color:var(--accent2)}
.hero h1{font-size:52px;font-weight:800;line-height:1.1;margin:16px 0 20px;letter-spacing:-1.4px;max-width:660px}
.hero h1 em{font-style:normal;background:linear-gradient(90deg,var(--accent2),#7BE3F2);-webkit-background-clip:text;background-clip:text;color:transparent}
.hero p.lead{font-size:18.5px;color:#C9E2E7;max-width:560px;margin-bottom:30px}
.hero-ctas{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:32px}
.hero-chips{display:flex;gap:22px;flex-wrap:wrap;font-size:13.5px;color:#9FC5CC}
.hero-chips b{color:#fff}
.hero-chips span::before{content:'\2713  ';color:var(--accent2);font-weight:800}
/* glass status cards floating over the live scene */
.glass{position:absolute;z-index:3;background:rgba(7,38,45,.58);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border:1px solid rgba(34,184,207,.38);border-radius:14px;padding:14px 18px;box-shadow:0 18px 44px rgba(0,0,0,.45);font-size:12.5px;color:#C9E2E7;animation:floaty 6s ease-in-out infinite}
.glass b{display:block;font-size:16px;color:#fff;margin-bottom:2px}
.glass .dot{display:inline-block;width:8px;height:8px;border-radius:50%;background:#2BE39B;margin-right:7px;box-shadow:0 0 0 0 rgba(43,227,155,.6);animation:pulse 2s infinite}
.g1{top:20%;right:5.5%}
.g2{bottom:30%;right:19%;animation-delay:1.6s}
.g3{top:47%;right:3.5%;animation-delay:3.1s}
.g3 .bar{width:150px;height:6px;background:rgba(255,255,255,.18);border-radius:99px;margin-top:8px;overflow:hidden}
.g3 .bar i{display:block;height:100%;width:87%;border-radius:99px;background:linear-gradient(90deg,var(--accent),var(--accent2))}
@keyframes floaty{0%,100%{transform:translateY(0)}50%{transform:translateY(-9px)}}
@keyframes pulse{0%{box-shadow:0 0 0 0 rgba(43,227,155,.55)}70%{box-shadow:0 0 0 9px rgba(43,227,155,0)}100%{box-shadow:0 0 0 0 rgba(43,227,155,0)}}
.price-strip{position:relative;z-index:4;background:rgba(4,30,36,.72);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);border-top:1px solid rgba(255,255,255,.12)}
.price-strip .wrap{display:flex;gap:0;justify-content:space-between;flex-wrap:wrap;padding:18px 24px}
.ps-item{text-align:center;padding:6px 18px}
.ps-item b{display:block;font-size:22px;color:#fff;font-weight:800}
.ps-item span{font-size:12px;color:#9FC5CC;text-transform:uppercase;letter-spacing:1.2px}

/* ===== USP STRIP ===== */
.usps{padding:70px 0 10px}
.usp-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;margin-top:34px}
.usp{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:28px;position:relative;transition:all .2s}
.usp:hover{transform:translateY(-4px);box-shadow:0 14px 34px rgba(21,23,28,.09);border-color:var(--accent2)}
.usp .ic{width:52px;height:52px;border-radius:13px;background:var(--accent-weak);display:flex;align-items:center;justify-content:center;font-size:24px;margin-bottom:16px}
.usp h3{font-size:18.5px;font-weight:800;margin-bottom:8px}
.usp p{font-size:14.5px;color:var(--ink2)}
.usp .tag-first{position:absolute;top:18px;right:18px;background:var(--warn-w);color:var(--warn);font-size:10.5px;font-weight:800;letter-spacing:1px;padding:4px 10px;border-radius:999px}

/* ===== GATE SECTION ===== */
.gate{background:linear-gradient(160deg,var(--cov1),var(--cov2));color:#fff;margin:80px 0;position:relative;overflow:hidden}
.gate::before{content:'';position:absolute;top:0;left:0;right:0;height:5px;background:linear-gradient(90deg,var(--accent),var(--accent2))}
.gate-in{display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center;padding:80px 24px;max-width:1180px;margin:0 auto}
.gate .kicker{color:var(--accent2)}
.gate h2{font-size:36px;font-weight:800;line-height:1.18;margin:12px 0 16px;letter-spacing:-.5px}
.gate p{color:#C9E2E7;font-size:16.5px;margin-bottom:14px}
.gate ul{list-style:none;margin-top:18px}
.gate li{padding:9px 0 9px 34px;position:relative;color:#DFF0F3;font-size:15px}
.gate li::before{content:'✓';position:absolute;left:0;top:8px;width:22px;height:22px;background:rgba(34,184,207,.2);color:var(--accent2);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:800}
.flow{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:18px;padding:30px}
.flow-step{display:flex;gap:16px;align-items:flex-start;padding:16px 0;border-bottom:1px solid rgba(255,255,255,.09)}
.flow-step:last-child{border-bottom:none}
.flow-step .n{width:40px;height:40px;flex-shrink:0;border-radius:11px;background:linear-gradient(135deg,var(--accent),var(--accent2));display:flex;align-items:center;justify-content:center;font-size:19px}
.flow-step b{display:block;font-size:15.5px;margin-bottom:2px}
.flow-step span{font-size:13.5px;color:#9FC5CC}

/* ===== FEATURES ===== */
.features{padding:10px 0 40px}
.feat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:36px}
.feat{background:var(--card2);border:1px solid var(--border);border-radius:14px;padding:24px}
.feat h4{font-size:16px;font-weight:800;color:var(--deep);margin-bottom:10px;display:flex;align-items:center;gap:10px}
.feat h4 .fi{width:34px;height:34px;border-radius:9px;background:var(--accent-weak);display:flex;align-items:center;justify-content:center;font-size:16px}
.feat ul{list-style:none}
.feat li{font-size:13.8px;color:var(--ink2);padding:5px 0 5px 20px;position:relative}
.feat li::before{content:'•';color:var(--accent);position:absolute;left:6px;font-weight:800}

/* ===== PRICING ===== */
.pricing{background:var(--canvas);padding:80px 0;border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.toggles{display:flex;gap:16px;justify-content:center;margin:30px 0 8px;flex-wrap:wrap}
.toggle{display:inline-flex;background:#fff;border:1.5px solid var(--border2);border-radius:999px;padding:4px}
.toggle button{border:none;background:transparent;padding:9px 22px;border-radius:999px;font-weight:700;font-size:14px;color:var(--ink2);cursor:pointer;font-family:inherit}
.toggle button.on{background:linear-gradient(135deg,var(--accent),#1899AE);color:#fff}
.cloud-note{text-align:center;font-size:13px;color:var(--ink3);margin-bottom:26px;min-height:20px}
.plans{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;align-items:stretch}
.plan{background:#fff;border:1px solid var(--border);border-radius:18px;padding:28px 24px;display:flex;flex-direction:column;position:relative}
.plan.pop{border:2px solid var(--accent);box-shadow:0 18px 44px rgba(14,124,143,.16)}
.plan .pop-tag{position:absolute;top:-13px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,var(--accent),var(--accent2));color:#fff;font-size:11px;font-weight:800;letter-spacing:1.5px;padding:5px 16px;border-radius:999px;white-space:nowrap}
.plan h3{font-size:17px;font-weight:800}
.plan .for{font-size:12.5px;color:var(--ink3);margin:2px 0 16px;min-height:32px}
.plan .price{font-size:38px;font-weight:800;letter-spacing:-1px}
.plan .price small{font-size:13px;font-weight:600;color:var(--ink3);letter-spacing:0}
.plan .per{font-size:12px;color:var(--ink3);margin-bottom:18px;min-height:16px}
.plan ul{list-style:none;flex:1;margin-bottom:20px}
.plan li{font-size:13.5px;color:var(--ink2);padding:5.5px 0 5.5px 24px;position:relative;border-bottom:1px solid var(--hairline)}
.plan li::before{content:'✓';color:var(--ok);position:absolute;left:2px;font-weight:800;font-size:12px}
.plan li.no{color:var(--ink3)}
.plan li.no::before{content:'—';color:var(--border2)}
.plan .btn{width:100%;text-align:center}
.pr-foot{text-align:center;font-size:13px;color:var(--ink3);margin-top:22px}
.pr-foot b{color:var(--deep)}

/* ===== CALCULATOR ===== */
.calc{background:#fff;border:1px solid var(--border);border-radius:20px;padding:36px;margin-top:46px;box-shadow:0 10px 34px rgba(21,23,28,.06)}
.calc-grid{display:grid;grid-template-columns:1.2fr .8fr;gap:40px;align-items:center}
.calc h3{font-size:22px;font-weight:800;margin-bottom:6px}
.calc .cs{font-size:14px;color:var(--ink2);margin-bottom:24px}
.calc input[type=range]{width:100%;accent-color:var(--accent);height:6px;cursor:pointer}
.calc .devrow{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:8px}
.calc .devnum{font-size:34px;font-weight:800;color:var(--accent)}
.calc .tier{font-size:12.5px;color:var(--ink3);margin-top:8px}
.calc .tier b{color:var(--deep)}
.calc-out{background:var(--accent-weak);border-radius:16px;padding:26px;text-align:center}
.calc-out .lbl{font-size:11.5px;letter-spacing:1.5px;text-transform:uppercase;color:var(--deep);font-weight:800}
.calc-out .big{font-size:36px;font-weight:800;color:var(--deep);margin:4px 0}
.calc-out .sm{font-size:13px;color:var(--deep);opacity:.8}
.calc-out hr{border:none;border-top:1px solid rgba(11,99,115,.18);margin:14px 0}
.calc-example{margin-top:20px;background:var(--warn-w);border-left:4px solid var(--warn);border-radius:0 10px 10px 0;padding:12px 16px;font-size:13.5px;color:#7A5614}

/* ===== COMPARE ===== */
.compare{padding:80px 0 30px}
table.cmp{width:100%;border-collapse:collapse;margin-top:34px;background:#fff;border-radius:16px;overflow:hidden;box-shadow:0 6px 24px rgba(21,23,28,.06)}
.cmp th{background:var(--accent-weak);color:var(--deep);text-align:left;padding:15px 18px;font-size:14.5px}
.cmp th:first-child{width:34%}
.cmp td{padding:13px 18px;border-top:1px solid var(--hairline);font-size:14px;color:var(--ink2)}
.cmp td:first-child{font-weight:700;color:var(--ink)}
.cmp .hl{color:var(--accent);font-weight:700}

/* ===== ECOSYSTEM ===== */
.eco{background:var(--canvas);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:56px 0;margin-top:50px}
.eco-in{display:flex;gap:36px;align-items:center;justify-content:space-between;flex-wrap:wrap}
.eco h3{font-size:24px;font-weight:800;margin-bottom:8px}
.eco p{color:var(--ink2);max-width:560px;font-size:15px}
.eco .offer{background:#fff;border:2px dashed var(--accent);border-radius:14px;padding:20px 26px;text-align:center}
.eco .offer b{display:block;font-size:30px;color:var(--accent);font-weight:800}
.eco .offer span{font-size:12.5px;color:var(--ink3)}

/* ===== FAQ ===== */
.faq{padding:80px 0}
.faq-item{border:1px solid var(--border);border-radius:12px;margin-top:12px;background:#fff;overflow:hidden}
.faq-q{width:100%;text-align:left;background:none;border:none;padding:18px 22px;font-size:15.5px;font-weight:700;color:var(--ink);cursor:pointer;display:flex;justify-content:space-between;align-items:center;font-family:inherit}
.faq-q::after{content:'+';font-size:22px;color:var(--accent);font-weight:400;transition:transform .2s}
.faq-item.open .faq-q::after{transform:rotate(45deg)}
.faq-a{max-height:0;overflow:hidden;transition:max-height .25s ease}
.faq-a p{padding:0 22px 18px;font-size:14.5px;color:var(--ink2)}

/* ===== CTA / LEAD ===== */
.cta{background:linear-gradient(160deg,var(--cov1),var(--cov3));color:#fff;padding:80px 0;position:relative}
.cta::before{content:'';position:absolute;top:0;left:0;right:0;height:5px;background:linear-gradient(90deg,var(--accent),var(--accent2))}
.cta-in{display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center}
.cta h2{font-size:34px;font-weight:800;line-height:1.2;margin:10px 0 14px}
.cta p{color:#C9E2E7;font-size:16px;margin-bottom:22px}
.leadform{background:#fff;border-radius:18px;padding:30px;color:var(--ink);box-shadow:0 24px 60px rgba(0,0,0,.35)}
.leadform h3{font-size:19px;font-weight:800;margin-bottom:4px}
.leadform .fs{font-size:13px;color:var(--ink3);margin-bottom:18px}
.leadform label{display:block;font-size:12.5px;font-weight:700;color:var(--ink2);margin:12px 0 5px}
.leadform input,.leadform select{width:100%;padding:11px 13px;border:1.5px solid var(--border2);border-radius:9px;font-size:14.5px;font-family:inherit;color:var(--ink);background:#fff}
.leadform input:focus,.leadform select:focus{outline:none;border-color:var(--accent)}
.leadform .btn{width:100%;margin-top:18px}
.leadform .wa-note{text-align:center;font-size:12px;color:var(--ink3);margin-top:10px}

/* ===== FOOTER ===== */
footer{background:var(--cov1);color:#9FC5CC;padding:56px 0 30px}
.foot-grid{display:grid;grid-template-columns:1.4fr 1fr .9fr 1fr 1.2fr;gap:32px}
.foot-logo img{height:64px;margin-bottom:14px}
.foot-grid p,.foot-grid li{font-size:13.5px;line-height:1.8}
.foot-grid h5{color:#fff;font-size:13px;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:14px}
.foot-grid ul{list-style:none}
.foot-grid a:hover{color:var(--accent2)}
.foot-base{border-top:1px solid rgba(255,255,255,.1);margin-top:40px;padding-top:22px;display:flex;justify-content:space-between;flex-wrap:wrap;gap:10px;font-size:12.5px}

/* ===== RESPONSIVE ===== */
@media(max-width:960px){
  .glass{display:none}
  .hero-in{min-height:520px;padding:84px 24px 120px}
  .hero-in,.gate-in,.cta-in,.calc-grid{grid-template-columns:1fr}
  .usp-grid,.feat-grid{grid-template-columns:1fr 1fr}
  .plans{grid-template-columns:1fr 1fr}
  .foot-grid{grid-template-columns:1fr 1fr}
  .hero h1{font-size:38px}
  .hamb{display:block}
  .nav-links{display:flex;position:absolute;top:72px;left:0;right:0;background:#fff;flex-direction:column;padding:12px 22px 16px;border-bottom:1px solid var(--border);gap:4px;margin-left:0;flex:none;z-index:200;box-shadow:0 22px 44px rgba(4,37,44,.18);opacity:0;visibility:hidden;transform:translateY(-12px);transition:opacity .22s ease,transform .22s ease,visibility .22s}
  .nav-links.openm{opacity:1;visibility:visible;transform:none}
  .nav-links a{padding:12px 4px;font-size:15px;border-bottom:1px solid var(--hair)}
  .nav-links a:last-child{border-bottom:none}
  .nav-in{padding:0 16px;gap:14px}
}
@media(max-width:600px){
  .nav-cta .login{display:none}
  .nav-cta .trial{padding:9px 14px;font-size:13px;white-space:nowrap}
  .usp-grid,.feat-grid,.plans{grid-template-columns:1fr}
  .hero h1{font-size:32px}
  h2.sec{font-size:27px}
  .foot-grid{grid-template-columns:1fr}
  .ps-item{padding:6px 10px}
  .ps-item b{font-size:17px}
}
</style>
<style id="paper-theme">:root{--canvas:#FBFAF6;--card2:#FCFBF8;--border:#ECE7DD;--border2:#E3DCD0;--hairline:#F2EDE4}</style>
<style id="usp-premium">
.usps{padding:90px 0 24px}
.usp{padding:34px 30px;border-radius:20px;overflow:hidden;box-shadow:0 1px 2px rgba(11,99,115,.04),0 8px 24px rgba(15,23,42,.05)}
.usp::before{content:"";position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--accent),var(--accent2));opacity:0;transition:opacity .25s}
.usp:hover::before{opacity:1}
.usp:hover{box-shadow:0 18px 46px rgba(11,99,115,.13)}
.usp .ic{width:60px;height:60px;border-radius:17px;margin-bottom:22px;background:linear-gradient(140deg,var(--accent),var(--deep));box-shadow:0 8px 20px rgba(14,124,143,.30),inset 0 1px 0 rgba(255,255,255,.28)}
.usp .ic svg{width:30px;height:30px;color:#fff}
.usp h3{font-size:21px;letter-spacing:-.02em;margin-bottom:12px}
.usp p{font-size:15px;color:var(--ink2)}
.tag-first{background:linear-gradient(135deg,var(--accent),var(--deep));color:#fff;box-shadow:0 4px 12px rgba(14,124,143,.30);padding:5px 12px}
</style>
<style id="feat-premium">
.features{padding:22px 0 52px}
.feat{background:var(--card);border-radius:18px;padding:22px 24px 24px;position:relative;overflow:hidden;z-index:0;box-shadow:0 1px 2px rgba(11,99,115,.04),0 6px 20px rgba(15,23,42,.05);transition:transform .2s,box-shadow .2s}
.feat:hover{transform:translateY(-4px);box-shadow:0 16px 42px rgba(11,99,115,.13)}
/* diagonal teal corner ribbon */
.feat::before{content:"";position:absolute;top:0;left:0;width:84px;height:84px;background:linear-gradient(135deg,var(--deep),var(--accent));-webkit-clip-path:polygon(0 0,100% 0,0 100%);clip-path:polygon(0 0,100% 0,0 100%);z-index:1}
/* icon sits ON the ribbon, white */
.feat h4 .fi,.fi{position:absolute;top:9px;left:9px;width:auto;height:auto;background:none;box-shadow:none;border-radius:0;z-index:2}
.fi svg,.feat h4 .fi svg{width:30px;height:30px;color:#fff;stroke-width:2.6}
/* title clears the ribbon */
.feat h4{padding-left:46px;min-height:56px;display:flex;align-items:center;gap:0;font-size:16.5px;margin-bottom:12px}
.feat ul{position:relative;z-index:2}
</style>
</head>
